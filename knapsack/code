#include <stdio.h>

struct Item {
    int id;
    float weight;
    float profit;
    float ratio;
};

void knapsack(int n, struct Item items[], float capacity) {
    float totalProfit = 0.0;
    float x[20]; // Array to store the fraction of each object taken
    int i;


    for (i = 0; i < n; i++) {
        x[i] = 0.0;
    }

    float currentCapacity = capacity;

    for (i = 0; i < n; i++) {
        if (items[i].weight <= currentCapacity) {
            // Step 3 (Part 1): If object fits completely
            x[i] = 1.0;
            totalProfit += items[i].profit;
            currentCapacity -= items[i].weight;
        } else {
            // Step 3 (Part 2): If object doesn't fit, take a fraction
            x[i] = currentCapacity / items[i].weight;
            totalProfit += (x[i] * items[i].profit);
            currentCapacity = 0;
            break; // Bag is full
        }
    }

    printf("\n--- Result ---\n");
    printf("Maximum Profit: %.2f\n", totalProfit);
    printf("Fractions of objects taken: ");
    for (i = 0; i < n; i++) {
        printf("Obj %d: %.2f  ", items[i].id, x[i]);
    }
    printf("\n");
}

int main() {
    int n, i, j;
    float capacity;
    struct Item items[20], temp;

    printf("Enter number of objects: ");
    scanf("%d", &n);

    printf("Enter capacity of the bag: ");
    scanf("%f", &capacity);

    for (i = 0; i < n; i++) {
        items[i].id = i + 1;
        printf("Enter Profit and Weight for object %d: ", i + 1);
        scanf("%f %f", &items[i].profit, &items[i].weight);


        items[i].ratio = items[i].profit / items[i].weight;
    }


    for (i = 0; i < n - 1; i++) {
        for (j = 0; j < n - i - 1; j++) {
            if (items[j].ratio < items[j + 1].ratio) {
                temp = items[j];
                items[j] = items[j + 1];
                items[j + 1] = temp;
            }
        }
    }

    knapsack(n, items, capacity);

    return 0;
}
